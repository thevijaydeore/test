# API Webhook URLs
# Copy this file to .env.local and add your actual webhook URLs

# Contact Form Webhook (n8n, Make.com, or custom API endpoint)
VITE_CONTACT_WEBHOOK_URL=https://your-webhook-url.com/contact

# Booking Form Webhook (n8n, Make.com, or custom API endpoint)
VITE_BOOKING_WEBHOOK_URL=https://your-webhook-url.com/booking
